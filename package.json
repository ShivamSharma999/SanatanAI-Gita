{
  "name": "gita",
  "version": "1.0.1",
  "description": "Bhagvat Gita for Santan AI",
  "icon": "./assets/favicon.ico",
  "keywords": [
    "Dharma",
    "AI",
    "Gita",
    "Sanatan",
    "Sanatan",
    "AI",
    "Bhagvat",
    "Gita"
  ],
  "license": "ISC",
  "author": "Shivam Sharma",
  "type": "commonjs",
  "main": "window.js",
  "scripts": {
    "test": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.sanatanai.gita",
    "productName": "Gita",
    "files": [
      "**/*",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ShivamSharma999",
        "repo": "SanatanAI-Gita"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gita",
      "deleteAppDataOnUninstall": true,
      "allowElevation": false,
      "artifactName": "Gita-Setup-${version}.${ext}"
    }
  }
}
