{
  "name": "gita",
  "version": "1.0.0",
  "description": "Bhagvat Gita for Santan AI",
  "icon": "./assets/favicon.ico",
  "keywords": [
    "Dharma",
    "AI",
    "Gita",
    "Sanatan",
    "Sanatan",
    "AI",
    "Bhagvat",
    "Gita"
  ],
  "license": "ISC",
  "author": "Shivam Sharma",
  "type": "commonjs",
  "main": "window.js",
  "scripts": {
    "test": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {},
  "build": {
    "appId": "com.sanatanai.gita",
    "productName": "Gita",
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gita",
      "perMachine": true,
      "deleteAppDataOnUninstall": true,
      "allowElevation": false
    }
  }
}
